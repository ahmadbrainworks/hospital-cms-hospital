# ============================================================
# HOSPITAL CMS — Client Instance Environment Variables
#
# MOST VALUES ARE AUTO-GENERATED BY THE INSTALLER.
# On first run, visit the web UI to complete installation.
# The installer collects MongoDB, Redis, admin credentials,
# generates all secrets, and stores everything in .data/installer.lock.
#
# This file is only needed for:
#   1. Overriding installer-generated values
#   2. Setting values the installer doesn't collect (ports, CORS, etc.)
#   3. Docker Compose deployments (pre-provisioned config)
# ============================================================

# --- Node Environment ---
NODE_ENV=development

# --- Data Directory ---
# All generated files (keys, lock file, state, packages) live here.
# Defaults to .data/ in the project root. Override for production.
# HOSPITAL_DATA_DIR=.data

# --- Infrastructure ---
# These run on localhost by default. The installer tests connectivity
# on startup — no need to enter them manually.
MONGODB_URI=mongodb://localhost:27017/hospital_cms
MONGODB_DB_NAME=hospital_cms
REDIS_URL=redis://localhost:6379

# --- Vendor Control Panel ---
# Hardcoded to https://cp-api.hospitalcms.com — do not change.
# CONTROL_PANEL_URL is set automatically by the application.

# --- Secrets (auto-generated by installer) ---
# All secrets below are generated during installation and loaded from
# the lock file automatically. Set here only to override.
# JWT_SECRET=
JWT_EXPIRY=15m
# REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d
# ENCRYPTION_KEY=
# MFA_ENCRYPTION_KEY=
# AGENT_SECRET=
# API_ADMIN_TOKEN=

# --- Instance Identity (auto-generated by installer) ---
# INSTANCE_ID=
# VENDOR_PUBLIC_KEY=

# --- API Server ---
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Agent ---
AGENT_VERSION=1.0.0
HEARTBEAT_INTERVAL_MS=30000

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info
METRICS_ENABLED=true
