# ============================================================
# ROOT ENV TEMPLATE
# This file now tracks the hospital-side deployment only.
#
# Use:
#   - .env.example or .env.hospital.example for hospital installs
#   - .env.control-panel.example for the vendor control panel
# ============================================================

HOSPITAL_PUBLIC_ORIGIN=http://localhost:8080
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/hospital_cms
MONGODB_DB_NAME=hospital_cms
REDIS_URL=redis://localhost:6379
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
REFRESH_TOKEN_EXPIRY=7d
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY
MFA_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY
CONTROL_PANEL_URL=https://cp.yourdomain.com
NEXT_PUBLIC_CONTROL_PANEL_URL=https://cp.yourdomain.com
INSTANCE_ID=
INSTANCE_PRIVATE_KEY_PATH=/etc/hospital-cms/instance.key
INSTANCE_PUBLIC_KEY_PATH=/etc/hospital-cms/instance.pub
VENDOR_PUBLIC_KEY=
AGENT_VERSION=1.0.0
HEARTBEAT_INTERVAL_MS=30000
STATE_FILE_PATH=/var/lib/hospital-agent/state.json
PACKAGES_DIR=/var/lib/hospital-agent/packages
AGENT_PRIVATE_KEY=
AGENT_PRIVATE_KEY_PATH=/etc/hospital-cms/instance.key
API_BASE_URL=http://localhost:4000
API_ADMIN_TOKEN=REPLACE_WITH_AGENT_SHARED_SECRET
AGENT_SECRET=REPLACE_WITH_SAME_AGENT_SHARED_SECRET
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:8080
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_INSTANCE_ID=
INSTALLER_PORT=3001
INSTALLER_LOCK_FILE=/etc/hospital-cms/installer.lock
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
PLUGIN_STORAGE_PATH=/var/hospital-cms/plugins
THEME_STORAGE_PATH=/var/hospital-cms/themes
LOG_LEVEL=info
METRICS_ENABLED=true
