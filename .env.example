# ============================================================
# HOSPITAL CMS — Client Instance Environment Variables
# Copy to .env and fill in values before deploying to a hospital.
#
# This file is for the CLIENT side (hospital infrastructure) and works with:
#   docker compose --env-file .env -f docker-compose.yml up -d --build
#
# It covers:
#   - apps/api (Express backend)
#   - apps/web (Next.js frontend)
#   - apps/agent (management daemon)
# ============================================================

# --- Public URL for hospital users (reverse-proxy entrypoint) ---
# Example local test URL: http://localhost:8080
HOSPITAL_PUBLIC_ORIGIN=http://localhost:8080

# --- Node Environment ---
NODE_ENV=production

# --- MongoDB (hospital's own database) ---
MONGODB_URI=mongodb://localhost:27017/hospital_cms
MONGODB_DB_NAME=hospital_cms

# --- Redis (sessions, rate limiting, caching) ---
REDIS_URL=redis://localhost:6379

# --- JWT / Auth (hospital staff authentication) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
REFRESH_TOKEN_EXPIRY=7d

# --- AES Encryption (secrets at rest) ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# --- MFA Encryption ---
# Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# ============================================================
# VENDOR CONTROL PANEL COMMUNICATION
# ============================================================
# The URL of YOUR vendor control panel server.
# The agent daemon sends heartbeats here and receives:
#   - License tokens
#   - Package assignments (plugins, themes)
#   - Remote commands
#   - Desired state updates
#
# Examples:
#   Development:  http://localhost:4001
#   Production:   https://cp.hospitalcms.com
CONTROL_PANEL_URL=https://cp.hospitalcms.com

# Optional: pre-fill the installer UI when building the web app manually.
# In the Docker hospital stack this is derived from CONTROL_PANEL_URL.
NEXT_PUBLIC_CONTROL_PANEL_URL=https://cp.hospitalcms.com

# --- Instance Identity (created by installer, or pre-provisioned) ---
# UUID assigned to this hospital instance. If omitted, the agent will read it
# from the installer lock file after installation completes.
INSTANCE_ID=

# RSA-4096 key paths (generated during installation)
INSTANCE_PRIVATE_KEY_PATH=/etc/hospital-cms/instance.key
INSTANCE_PUBLIC_KEY_PATH=/etc/hospital-cms/instance.pub

# --- Vendor Public Key (RSA-4096 PEM) ---
# Used to verify signed licenses, commands, and packages from the vendor.
# Get this from your vendor control panel admin.
VENDOR_PUBLIC_KEY=

# --- Agent Configuration ---
AGENT_VERSION=1.0.0
HEARTBEAT_INTERVAL_MS=30000
STATE_FILE_PATH=/var/lib/hospital-agent/state.json
PACKAGES_DIR=/var/lib/hospital-agent/packages
# Optional: if AGENT_PRIVATE_KEY is blank, the agent loads the PEM from
# AGENT_PRIVATE_KEY_PATH after the installer writes the key to disk.
AGENT_PRIVATE_KEY=
# Path for key rotation persistence (optional)
AGENT_PRIVATE_KEY_PATH=/etc/hospital-cms/instance.key

# Agent's local API access (shared secret with hospital API)
API_BASE_URL=http://localhost:4000
API_ADMIN_TOKEN=REPLACE_WITH_AGENT_SHARED_SECRET
AGENT_SECRET=REPLACE_WITH_SAME_AGENT_SHARED_SECRET

# --- API Server ---
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:8080

# --- Frontend ---
# Leave empty when the web app is served behind the hospital reverse proxy.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_INSTANCE_ID=

# --- Installer ---
INSTALLER_PORT=3001
INSTALLER_LOCK_FILE=/etc/hospital-cms/installer.lock

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Storage ---
PLUGIN_STORAGE_PATH=/var/hospital-cms/plugins
THEME_STORAGE_PATH=/var/hospital-cms/themes

# --- Logging ---
LOG_LEVEL=info
METRICS_ENABLED=true
