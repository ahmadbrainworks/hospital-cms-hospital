[Unit]
Description=Hospital CMS Agent
After=network.target hospital-api.service
Wants=network.target

[Service]
Type=simple
User=hospitalcms
Group=hospitalcms
WorkingDirectory=/opt/hospital-cms
EnvironmentFile=/etc/hospital-cms/hospital.env
ExecStart=/usr/bin/env pnpm --dir /opt/hospital-cms/apps/agent start
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
