{
  "name": "@hospital-cms/auth",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "mongodb": "^6.3.0",
    "@hospital-cms/config": "workspace:*",
    "@hospital-cms/shared-types": "workspace:*",
    "@hospital-cms/errors": "workspace:*",
    "@hospital-cms/logger": "workspace:*",
    "@hospital-cms/crypto": "workspace:*",
    "@hospital-cms/database": "workspace:*"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
