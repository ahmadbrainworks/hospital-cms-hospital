# ── Stage 1: Build ─────────────────────────────────────────────
FROM node:22-alpine AS builder

RUN corepack enable && corepack prepare pnpm@10.32.0 --activate

WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.json ./

COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY apps/agent/package.json apps/agent/
COPY apps/control-panel/package.json apps/control-panel/
COPY apps/vendor-dashboard/package.json apps/vendor-dashboard/
COPY packages/shared-types/package.json packages/shared-types/
COPY packages/config/package.json packages/config/
COPY packages/contracts/package.json packages/contracts/
COPY packages/crypto/package.json packages/crypto/
COPY packages/crypto-vendor/package.json packages/crypto-vendor/
COPY packages/database/package.json packages/database/
COPY packages/errors/package.json packages/errors/
COPY packages/logger/package.json packages/logger/
COPY packages/auth/package.json packages/auth/
COPY packages/rbac/package.json packages/rbac/
COPY packages/audit/package.json packages/audit/
COPY packages/plugin-runtime/package.json packages/plugin-runtime/
COPY packages/theme-engine/package.json packages/theme-engine/
COPY packages/workflow-engine/package.json packages/workflow-engine/
COPY plugins/patient-alerts/package.json plugins/patient-alerts/
COPY plugins/sample-bed-tracker/package.json plugins/sample-bed-tracker/

RUN pnpm install --frozen-lockfile

COPY packages/ packages/
COPY apps/web/ apps/web/

ARG NEXT_PUBLIC_API_URL=
ARG NEXT_PUBLIC_CONTROL_PANEL_URL=
ARG API_INTERNAL_URL=http://api:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_CONTROL_PANEL_URL=$NEXT_PUBLIC_CONTROL_PANEL_URL
ENV API_INTERNAL_URL=$API_INTERNAL_URL

RUN cd apps/web && npx next build

# ── Stage 2: Production ───────────────────────────────────────
FROM node:22-alpine AS runner

RUN addgroup --system cms && adduser --system --ingroup cms cms

WORKDIR /app

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static

USER cms
EXPOSE 3000

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
