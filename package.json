{
  "name": "hospital-cms",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:hospital": "turbo run build --filter=@hospital-cms/api --filter=@hospital-cms/web --filter=@hospital-cms/agent",
    "build:vendor": "turbo run build --filter=@hospital-cms/control-panel --filter=@hospital-cms/vendor-dashboard",
    "predev": "turbo run build --filter=@hospital-cms/api^... --filter=@hospital-cms/web^...",
    "dev": "turbo run dev --parallel --filter=@hospital-cms/api --filter=@hospital-cms/web",
    "dev:hospital": "turbo run dev --parallel --filter=@hospital-cms/api --filter=@hospital-cms/web --filter=@hospital-cms/agent",
    "dev:vendor": "turbo run dev --parallel --filter=@hospital-cms/control-panel --filter=@hospital-cms/vendor-dashboard",
    "predev:all": "turbo run build --filter=@hospital-cms/api^... --filter=@hospital-cms/web^... --filter=@hospital-cms/agent^... --filter=@hospital-cms/control-panel^... --filter=@hospital-cms/plugin-patient-alerts^...",
    "dev:all": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "prettier": "^3.1.0",
    "turbo": "^2.8.15",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.0"
}
